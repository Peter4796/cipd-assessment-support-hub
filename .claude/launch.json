{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cipd-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "cipd-dev-authpreview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3001"],
      "port": 3001,
      "env": {
        "ADMIN_USER": "preview",
        "ADMIN_PASSWORD": "preview-only-not-a-secret"
      }
    }
  ]
}
