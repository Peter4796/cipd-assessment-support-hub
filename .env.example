# ─────────────────────────────────────────────────────────────
# CIPD Guidance — environment variables
# Copy to `.env.local` for local dev; set in Vercel for production.
# The marketing site renders fully WITHOUT any of these, but LEAD CAPTURE
# requires the Resend block below — without it, /api/leads returns
# "delivery_failed" and the enquiry form falls back to direct WhatsApp/email.
# ─────────────────────────────────────────────────────────────

# Public site URL (canonicals, sitemap, OG). Already set in code; override if needed.
NEXT_PUBLIC_SITE_URL=https://www.cipdguidance.com

# ── LEAD CAPTURE (P0 — REQUIRED for the enquiry form to capture leads) ──
# 1. Create a free account at https://resend.com
# 2. Verify the cipdguidance.com domain (Resend → Domains → add DNS records
#    at Namecheap; same process as the Google verification TXT)
# 3. Create an API key and set it here + in Vercel (all environments)
RESEND_API_KEY=
# Verified sender the notifications come FROM (must be on the verified domain)
EMAIL_FROM=CIPD Guidance <leads@cipdguidance.com>
# Where internal lead notifications are delivered TO (any inbox you read)
LEAD_NOTIFY_EMAIL=georgekanja.10@gmail.com
# Optional: persistent subscriber storage for the lead magnet.
# Resend → Audiences → create one → paste its ID. Without it, subscriber
# capture falls back to notification email only.
RESEND_AUDIENCE_ID=

# ── Admin area lock (already live) ──
# HTTP Basic Auth for /admin (src/middleware.ts). Fails closed if unset.
ADMIN_USER=admin
ADMIN_PASSWORD=

# ── Deferred integrations (P1/P2 — documented boundaries, not yet wired) ──
# Database (Neon/Postgres) — persists leads + powers the real admin dashboard.
DATABASE_URL=
# File uploads (Vercel Blob) — real brief/feedback uploads land in P1.
BLOB_READ_WRITE_TOKEN=
# Payments (Stripe) — only if/when online payment is wanted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
