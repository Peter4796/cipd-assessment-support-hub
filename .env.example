# ─────────────────────────────────────────────────────────────
# CIPD Assessment Support Hub — environment variables
# Copy to `.env.local` and fill in when wiring up the live Phase 3 backend.
# The site runs fully WITHOUT any of these (marketing + demo portal).
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical tags, sitemap, OG). Already set in code;
# override here if you prefer.
NEXT_PUBLIC_SITE_URL=https://www.cipdguidance.com

# ── Database / backend (Supabase) ──
# Create a project at https://supabase.com and add a `projects` table mirroring
# src/lib/portal/types.ts, then move store.ts mutations behind API routes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ──
# If using Auth.js / Clerk instead of Supabase Auth, add their keys here.
AUTH_SECRET=
# Real admin access — replace the demo passcode in src/lib/portal/session.ts.
ADMIN_ALLOWED_EMAILS=

# ── Payments (Stripe) ──
# For real "secure payments": create Checkout Sessions server-side + verify webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Transactional email (Resend or SendGrid) ──
# For automated quote + status-update emails.
RESEND_API_KEY=
EMAIL_FROM=hello@cipdguidance.com

# ── WhatsApp Business API (optional) ──
# For automated WhatsApp notifications (the click-to-chat links need nothing).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
